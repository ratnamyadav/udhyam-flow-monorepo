# Neon Postgres connection (used by packages/db and BetterAuth via packages/auth)
DATABASE_URL="postgres://USER:PASSWORD@HOST/DB?sslmode=require"

# BetterAuth — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="replace-me-with-32-bytes-of-random"
BETTER_AUTH_URL="http://localhost:3000"

# Web app (apps/web)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_AUTH_URL="http://localhost:3000"

# Admin app (apps/admin)
ADMIN_AUTH_URL="http://localhost:3001"

# Mobile app (apps/mobile) — points at the web app's auth handler in dev
EXPO_PUBLIC_AUTH_URL="http://localhost:3000"
